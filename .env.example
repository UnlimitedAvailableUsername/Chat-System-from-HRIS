# Copy this file to .env.local and fill in your own values.
# Supabase credentials — get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Provider key — required for the AI Suggest feature.
# Recommended: do NOT expose API keys in the browser — proxy through a Supabase Edge Function for production.

# OpenAI — get from: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=sk-proj-...
